# Copy to .env.local and fill in. .env.local is gitignored — never commit real values.

# Agency brand shown across the UI (login, header, footer, settings, page title).
# Client-readable, so it MUST use the NEXT_PUBLIC_ prefix. Falls back to a built-in
# name when unset — set this in every environment (incl. Vercel) before going public.
NEXT_PUBLIC_AGENCY_NAME=

# Email the Settings "Request a change" button targets (only used for tenants with no
# Slack channel). Server-only. Leave unset to hide the button entirely.
AGENCY_CONTACT_EMAIL=

# Secret used to sign the session cookie. Generate with: openssl rand -hex 32
AFD_SESSION_SECRET=

# Assistable workspace API key (read-write, server-only). Locally this is usually
# already exported in your shell, so you can leave it unset here.
ASSISTABLE_API_KEY=

# Real tenants -> live Assistable data. JSON array, server-only (never sent to the browser).
# The built-in "demo" tenant (demo/demo, static sample data) always exists without this.
# Passwords are scrypt hashes, never plaintext. Generate one with:
#   bun scripts/hash-password.ts <password>
# Shape per tenant: slug, email, passwordHash, name, assistantName, timezone,
# subaccountId, and optionally slackChannelId (the "Message us on Slack" target).
AFD_TENANTS=[{"slug":"acme","email":"owner@acme.com","passwordHash":"<saltHex:hashHex from hash-password.ts>","name":"Acme Clinic","assistantName":"Ava","timezone":"America/New_York","subaccountId":"<assistable-subaccount-id>","slackChannelId":"C0ABC123XYZ"}]

# Admin accounts can log in and switch between ANY client (the agency view).
# Server-only. Passwords are scrypt hashes (bun scripts/hash-password.ts).
AFD_ADMINS=[{"email":"admin@youragency.com","passwordHash":"<saltHex:hashHex>","name":"Your Name"}]

# OPTIONAL: a Vercel KV or Upstash Redis integration. When set, admins can edit
# each tenant's Slack channel ID from the Settings page (persisted globally) instead
# of only via AFD_TENANTS above. Without it, the app runs env-only (read-only in UI).
# Either pair works (Vercel KV sets the KV_* names; Upstash sets the UPSTASH_* names):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
